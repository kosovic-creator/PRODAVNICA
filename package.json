{
  "name": "prodavnica",
  "version": "1.0.0",
  "description": "Prodavnica monorepo - admin dashboard i customer-facing aplikacija",
  "private": true,
  "packageManager": "npm@11.6.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "npm run db:generate --workspace=packages/database || true",
    "db:migrate": "npm run db:migrate --workspace=packages/database",
    "db:deploy": "npm run db:deploy --workspace=packages/database",
    "db:reset": "npm run db:reset --workspace=packages/database",
    "dev:client": "npm run dev --workspace=apps/prodavnica-client",
    "dev:klient": "npm run dev --workspace=apps/prodavnica-client",
    "dev:admin": "npm run dev --workspace=apps/prodavnica-admin",
    "dev": "concurrently \"npm run dev --workspace=apps/prodavnica-client\" \"npm run dev --workspace=apps/prodavnica-admin\"",
    "build:all": "npm run build --workspace=apps/prodavnica-client && npm run build --workspace=apps/prodavnica-admin",
    "build:vercel": "npm run db:generate --workspace=packages/database || true && if echo \"$VERCEL_PROJECT_PRODUCTION_URL$VERCEL_URL\" | grep -qi 'admin'; then npm run build --workspace=apps/prodavnica-admin; else npm run build --workspace=apps/prodavnica-client; fi",
    "build": "if [ \"$VERCEL\" = \"1\" ]; then npm run build:vercel; else npm run db:generate --workspace=packages/database || true && npm run build:all; fi",
    "build:admin": "npm run build --workspace=apps/prodavnica-admin",
    "build:klient": "npm run build --workspace=apps/prodavnica-client",
    "build:client": "npm run build --workspace=apps/prodavnica-client",
    "start:admin": "npm start --workspace=apps/prodavnica-admin",
    "start:klient": "npm start --workspace=apps/prodavnica-client",
    "start:client": "npm start --workspace=apps/prodavnica-client",
    "db:generate": "npm run db:generate --workspace=packages/database",
    "db:push": "npm run db:push --workspace=packages/database",
    "db:studio": "npm run db:studio --workspace=packages/database",
    "prisma:migrate:dev": "npm run migrate:dev --workspace=packages/database",
    "prisma:migrate:deploy": "npm run migrate:deploy --workspace=packages/database",
    "prisma:studio": "npm run studio --workspace=packages/database"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "next-pwa": "^5.6.0",
    "prisma": "^7.5.0"
  },
  "dependencies": {
    "@prisma/client": "^7.5.0"
  }
}
