{
  "name": "prodavnica",
  "version": "1.0.0",
  "description": "Prodavnica monorepo - admin dashboard i customer-facing aplikacija",
  "private": true,
  "packageManager": "npm@11.6.3",
  "workspaces": [
    "shared-prisma",
    "prodavnica-admin",
    "prodavnica-client"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "prisma:migrate:dev": "npm run migrate:dev -w shared-prisma",
    "prisma:migrate:deploy": "npm run migrate:deploy -w shared-prisma",
    "prisma:studio": "npm run studio -w shared-prisma"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "turbo": "^2.3.3"
  }
}
