{
  "name": "prodavnica",
  "version": "1.0.0",
  "description": "Prodavnica monorepo - admin dashboard i customer-facing aplikacija",
  "private": true,
  "packageManager": "npm@11.6.3",
  "workspaces": [
    "shared-prisma",
    "shared-lib",
    "shared-ui",
    "shared-validators",
    "prodavnica-admin",
    "prodavnica-client"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w prodavnica-admin\" \"npm run dev -w prodavnica-client\"",
    "build": "npm run build:admin && npm run build:client",
    "build:admin": "npm run build -w prodavnica-admin",
    "build:client": "npm run build -w prodavnica-client",
    "start:admin": "npm start -w prodavnica-admin",
    "start:client": "npm start -w prodavnica-client",
    "prisma:migrate:dev": "npm run migrate:dev -w shared-prisma",
    "prisma:migrate:deploy": "npm run migrate:deploy -w shared-prisma",
    "prisma:studio": "npm run studio -w shared-prisma"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
